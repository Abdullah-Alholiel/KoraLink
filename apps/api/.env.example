# Application
NODE_ENV=development
PORT=3001

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/koralink?schema=public"
# Set to 'require' when connecting to OCI / cloud Postgres over SSL
SSL_MODE=false

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=7d

# Cookie
COOKIE_SECRET=your-cookie-secret-change-in-production

# CORS Origins
PLAYER_URL=http://localhost:3000
ADMIN_URL=http://localhost:3002

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Unifonic (OTP provider)
UNIFONIC_APP_SID=your-unifonic-app-sid
UNIFONIC_SENDER_ID=KoraLink

# Moyasar (Payment gateway)
MOYASAR_SECRET_KEY=your-moyasar-secret-key
MOYASAR_PUBLISHABLE_KEY=your-moyasar-publishable-key
