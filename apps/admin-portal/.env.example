# Copy this file to .env.local and fill in your values
NEXT_PUBLIC_API_URL=https://api.koralink.sa
NEXT_PUBLIC_APP_URL=https://admin.koralink.sa
NEXT_PUBLIC_MINIO_URL=https://storage.koralink.sa

# 32+ character secret used to verify JWTs issued by the NestJS backend.
# Must match the JWT_SECRET configured in the NestJS service.
JWT_SECRET=change_me_to_a_secure_random_32_char_string
